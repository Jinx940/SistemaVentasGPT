PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/sistema_ventas_gpt
CORS_ORIGINS=http://localhost:5173
DATABASE_POOL_MAX=2
PUBLIC_BACKEND_URL=http://localhost:3001
CRON_SECRET=replace-with-a-random-secret-at-least-16-characters

# WhatsApp Cloud API (opcionales si prefieres configurarlo desde la UI)
WA_ENABLED=false
WA_GRAPH_VERSION=v25.0
WA_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WA_ACCESS_TOKEN=
WA_WEBHOOK_URL=http://localhost:3001/webhooks/whatsapp
WA_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-verification-token
WA_NOTIFY_PHONE=your-notification-phone
WA_TEMPLATE_REPLY_ALERT_NAME=gpt_alerta_respuesta
WA_TEMPLATE_REPLY_ALERT_LANG=es_PE
WA_TEMPLATE_NAME=gpt_vence_hoy
WA_LANG_CODE=es_PE
WA_TEMPLATE_DUE_TODAY_NAME=gpt_vence_hoy
WA_TEMPLATE_DUE_TODAY_LANG=es_PE
WA_TEMPLATE_DUE_TOMORROW_NAME=gpt_vence_manana
WA_TEMPLATE_DUE_TOMORROW_LANG=es_PE
WA_TEMPLATE_OVERDUE_NAME=gpt_plus_vencido
WA_TEMPLATE_OVERDUE_LANG=es_PE
WA_TEMPLATE_ACCESS_UPDATE_NAME=
WA_TEMPLATE_ACCESS_UPDATE_LANG=es_PE
WA_SERVICE_RESUME_DATE=01/03
WA_PAYMENT_METHODS=Yape / Plin
WA_PAYMENT_PHONE=your-payment-phone
WA_PAYMENT_CONTACT_NAME=Your Name
WA_AUTO_SEND_ENABLED=true
WA_AUTO_SEND_INTERVAL_MINUTES=15
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_TARGET_HOUR=3
AUTO_BACKUP_KEEP=7
